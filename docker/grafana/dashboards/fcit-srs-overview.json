{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {"list": []},
  "description": "FCIT SRS — System Overview Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Backend Status",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "targets": [{"expr": "up{job=\"fcit-srs-backend\"}", "legendFormat": "Backend"}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}, "mappings": [{"type": "value", "options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}}]}}
    },
    {
      "id": 2, "type": "stat", "title": "PostgreSQL Status",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "targets": [{"expr": "up{job=\"fcit-srs-postgres\"}", "legendFormat": "PostgreSQL"}],
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}, "mappings": [{"type": "value", "options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}}]}}
    },
    {
      "id": 3, "type": "stat", "title": "HTTP Request Rate (5m)",
      "gridPos": {"h": 4, "w": 8, "x": 8, "y": 0},
      "targets": [{"expr": "sum(rate(fcit_srs_http_requests_total[5m]))", "legendFormat": "req/s"}],
      "options": {"colorMode": "background", "graphMode": "area"},
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 4, "type": "stat", "title": "Active DB Connections",
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "targets": [{"expr": "pg_stat_activity_count{state=\"active\"}", "legendFormat": "Active"}],
      "options": {"colorMode": "background", "graphMode": "none"},
      "fieldConfig": {"defaults": {"thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 10}, {"color": "red", "value": 50}]}}}
    },
    {
      "id": 5, "type": "stat", "title": "Total DB Size",
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "targets": [{"expr": "pg_database_size_bytes{datname=\"student_registration_system\"}", "legendFormat": "DB Size"}],
      "options": {"colorMode": "value", "graphMode": "none"},
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 6, "type": "timeseries", "title": "HTTP Requests by Status Code",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "sum(rate(fcit_srs_http_requests_total[5m])) by (status_code)", "legendFormat": "{{status_code}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 7, "type": "timeseries", "title": "HTTP Request Latency (p95)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(fcit_srs_http_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95"},
        {"expr": "histogram_quantile(0.50, sum(rate(fcit_srs_http_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 8, "type": "timeseries", "title": "Login Attempts (success vs failure)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "sum(rate(fcit_srs_http_requests_total{path=\"/auth/login\",status_code=\"200\"}[5m]))", "legendFormat": "Success"},
        {"expr": "sum(rate(fcit_srs_http_requests_total{path=\"/auth/login\",status_code=\"401\"}[5m]))", "legendFormat": "Failed"}
      ]
    },
    {
      "id": 9, "type": "timeseries", "title": "PostgreSQL Transactions/s",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "rate(pg_stat_database_xact_commit_total{datname=\"student_registration_system\"}[5m])", "legendFormat": "Commits/s"},
        {"expr": "rate(pg_stat_database_xact_rollback_total{datname=\"student_registration_system\"}[5m])", "legendFormat": "Rollbacks/s"}
      ]
    },
    {
      "id": 10, "type": "timeseries", "title": "Node.js Memory Usage",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {"expr": "nodejs_heap_size_used_bytes", "legendFormat": "Heap Used"},
        {"expr": "nodejs_heap_size_total_bytes", "legendFormat": "Heap Total"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 11, "type": "timeseries", "title": "PostgreSQL Cache Hit Ratio",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {"expr": "pg_stat_database_blks_hit_total{datname=\"student_registration_system\"} / (pg_stat_database_blks_hit_total{datname=\"student_registration_system\"} + pg_stat_database_blks_read_total{datname=\"student_registration_system\"}) * 100", "legendFormat": "Cache Hit %"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100}}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["fcit-srs", "overview"],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "FCIT SRS Overview",
  "uid": "fcit-srs-overview",
  "version": 3
}
